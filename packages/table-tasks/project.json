{
  "name": "table-tasks",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/table-tasks/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/table-tasks"
      }
    },
    "test:browser": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "packages/table-tasks"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config vitest.unit.config.ts",
        "cwd": "packages/table-tasks"
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook dev -p 6009",
        "cwd": "packages/table-tasks"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook build",
        "cwd": "packages/table-tasks"
      }
    }
  }
}
